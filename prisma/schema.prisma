generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  description     String
  content         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  category        String?
  thumbnailUrl    String?
  published       Boolean   @default(false)
  tags            String[]  @default([])
  images          String[]  @default([])
  canonicalUrl    String?
  metaDescription String?
  metaKeywords    String[]  @default([])
  metaTitle       String?
  ogImage         String?
  publishedAt     DateTime?

  @@index([published, updatedAt])
  @@index([slug])
}

model Post {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         String
  authorId        String
  tags            String[]
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  coverUrl        String?
  metaDescription String?
  metaKeywords    String[]
  metaTitle       String?
  author          User       @relation(fields: [authorId], references: [id])
  categories      Category[] @relation("CategoryToPost")
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[] @relation("CategoryToPost")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  posts     Post[]
}

model CvRequest {
  id         String    @id @default(cuid())
  email      String
  source     String
  company    String?
  fullName   String
  phone      String?
  message    String?
  token      String    @unique
  verified   Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model SiteSetting {
  id           String   @id @default("singleton")
  defaultLang  String   @default("id")
  defaultTheme String   @default("system")
  seoTitle     String?
  seoDesc      String?
  i18n         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}
